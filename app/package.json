{
  "name": "hambros",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "hammurabi": "./hammurabi-cli.mjs"
  },
  "scripts": {
    "build:deps": "pnpm --filter @hambros/cli build && pnpm --filter @hambros/auth-providers build && pnpm --filter @hambros/telemetry build && pnpm --filter @hambros/sse-streaming build",
    "dev": "pnpm run build:deps && concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "pnpm run build:deps && vite build && tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "test": "pnpm run build:deps && vitest run",
    "lint": "eslint src server modules --ext .ts,.tsx",
    "onboard": "hammurabi onboard",
    "cap:sync": "cap sync ios",
    "cap:ios": "cap open ios",
    "cap:build": "pnpm build && cap sync ios"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.4.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@hambros/auth-providers": "workspace:*",
    "@hambros/cli": "workspace:*",
    "@hambros/sse-streaming": "workspace:*",
    "@hambros/telemetry": "workspace:*",
    "@pixi/react": "^8.0.5",
    "@tanstack/react-query": "^5.62.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jose": "^5.10.0",
    "lucide-react": "^0.468.0",
    "multer": "1.4.5-lts.2",
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "pixi.js": "^8.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@hambros/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.55.0",
    "vite": "^6.0.6",
    "vitest": "^2.1.0"
  }
}
